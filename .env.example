# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Exa.ai
EXA_API_KEY=your-exa-api-key

# Email delivery (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=digest@distill.app

# Base URL the digest email links back to (your deployed web app)
APP_BASE_URL=https://distill.app

# Supabase JWT secret — Project Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# Railway (set automatically in Railway environment)
PORT=8000
